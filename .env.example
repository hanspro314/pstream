# PStream Environment Variables
# Copy this file to .env and fill in your values

# ─── Database ────────────────────────────────────────────────
# Local development (SQLite):
# DATABASE_URL=file:./db/pstream.db

# Production (Turso cloud database):
DATABASE_URL=libsql://your-turso-instance.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# ─── API ─────────────────────────────────────────────────────
# API Token for content provider (dashboard + preview + search + episodes endpoints)
PSTREAM_API_TOKEN=

# User ID for the upstream movie API (identifies this subscriber)
MOVIE_API_USER_ID=

# ─── Admin ───────────────────────────────────────────────────
# Admin PIN for dashboard access (4-10 digits)
PSTREAM_ADMIN_PIN=1234
